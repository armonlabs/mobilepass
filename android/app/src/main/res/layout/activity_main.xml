<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	tools:context=".MainActivity">

	<ScrollView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:fillViewport="true">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginLeft="20dp"
			android:layout_marginRight="20dp"
			android:layout_marginTop="20dp"
			android:layout_marginBottom="20dp"
			android:orientation="vertical">

			<TextView
				android:id="@+id/armon_test_txtInfo"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Üye numaranızı giriniz" />

			<EditText
				android:id="@+id/armon_test_inputMemberId"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:ems="10"
				android:inputType="textPersonName"
				android:text="6982012" />

			<Button
				android:id="@+id/armon_test_btnStart"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:onClick="onButtonStartClicked"
				android:text="Başlat" />

			<Button
				android:id="@+id/armon_test_btnScanQR"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="16dp"
				android:onClick="onButtonScanQRClicked"
				android:text="📷 QR Kod Tara (Test)"
				android:backgroundTint="#4CAF50" />

			<Button
				android:id="@+id/armon_test_btnConfirmLocation"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:onClick="onButtonConfirmLocationClicked"
				android:text="📍 Konum Doğrulandı"
				android:backgroundTint="#2196F3" />

			<Button
				android:id="@+id/armon_test_btnSyncQRCodes"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:onClick="onButtonSyncQRCodesClicked"
				android:text="🔄 QR Listesi Güncelle"
				android:backgroundTint="#FF9800" />

			<Button
				android:id="@+id/armon_test_btnRequestPermissions"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:onClick="onButtonRequestPermissionsClicked"
				android:text="📋 İzinleri İste"
				android:backgroundTint="#9C27B0" />

			<Button
				android:id="@+id/armon_test_btnCancel"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:onClick="onButtonCancelFlowClicked"
				android:text="❌ İşlemi İptal Et"
				android:backgroundTint="#F44336" />

			<TextView
				android:id="@+id/armon_test_txtHelp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="24dp"
				android:text="💡 Test: QR kod burada mock veri olarak gönderiliyor.\nGerçek uygulamada kamera entegrasyonu yapılmalı."
				android:textSize="12sp"
				android:textColor="#666666"
				android:gravity="center" />

		</LinearLayout>
	</ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>